	file = {Full Text PDF:C\:\\Users\\c.aranzana\\Zotero\\storage\\WRRCGFUT\\Remigereau - 2024 - Bringing in the Far Right The Electoral Impact of the French Algerian Repatriates.pdf:application/pdf},
}

@unpublished{cefala_political_2024,
	title = {The {Political} {Consequences} of {Mass} {Repatriation} ‗},
	abstract = {What happens when a country’s electorate suddenly expands by hundreds of thousands of new voters? This study examines the political impact of the mass arrival of repatriates from Algeria to France. Using this quasi-experiment, I demonstrate that their arrival caused significant changes in the French electoral landscape. In areas of exposure to their arrival, they increased the French electorate and reshaped the vote for right-wing parties. Furthermore, their presence influenced candidates’ electoral strategies, causing all candidates to shift their electoral manifestos towards pro-repatriates stances. This significant historical event influenced French political life, reshaping electoral dynamics and political strategies in France.},
	language = {en},
	author = {Cefalà, Edoardo},
	year = {2024},
}

