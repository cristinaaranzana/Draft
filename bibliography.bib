@book{piketty_histoire_2023,
	title = {Une histoire du conflit politique: {Elections} et in{\'e}galit{\'e}s sociales en {France}, 1789-2022},
	isbn = {978-2-02-145455-0},
	shorttitle = {Une histoire du conflit politique},
	abstract = {Qui vote pour qui et pourquoi ? Comment la structure sociale des {\'e}lectorats des diff{\'e}rents courants politiques en France a-t-elle {\'e}volu{\'e} de 1789 {\`a} 2022 ? En s{\textquoteright}appuyant sur un travail in{\'e}dit de num{\'e}risation des donn{\'e}es {\'e}lectorales et socio-{\'e}conomiques des 36 000 communes de France couvrant plus de deux si{\`e}cles, cet ouvrage propose une histoire du vote et des in{\'e}galit{\'e}s {\`a} partir du laboratoire fran{\c c}ais.Au-del{\`a} de son int{\'e}r{\^e}t historique, ce livre apporte un regard neuf sur les crises du pr{\'e}sent et leur possible d{\'e}nouement. La tripartition de la vie politique issue des {\'e}lections de 2022, avec d{\textquoteright}une part un bloc central regroupant un {\'e}lectorat socialement beaucoup plus favoris{\'e} que la moyenne {\textendash} et r{\'e}unissant d{\textquoteright}apr{\`e}s les sources ici rassembl{\'e}es le vote le plus bourgeois de toute l{\textquoteright}histoire de France {\textendash}, et de l{\textquoteright}autre des classes populaires urbaines et rurales divis{\'e}es entre les deux autres blocs, ne peut {\^e}tre correctement analys{\'e}e qu{\textquoteright}en prenant le recul historique n{\'e}cessaire. En particulier, ce n{\textquoteright}est qu{\textquoteright}en remontant {\`a} la fin du 19e si{\`e}cle et au d{\'e}but du 20e si{\`e}cle, {\`a} une {\'e}poque o{\`u} l{\textquoteright}on observait des formes similaires de tripartition avant que la bipolarisation ne l{\textquoteright}emporte pendant la majeure partie du si{\`e}cle dernier, que l{\textquoteright}on peut comprendre les tensions {\`a} l{\textquoteright}oeuvre aujourd{\textquoteright}hui. La tripartition a toujours {\'e}t{\'e} instable alors que c{\textquoteright}est la bipartition qui a permis le progr{\`e}s {\'e}conomique et social. Comparer de fa{\c c}on minutieuse les diff{\'e}rentes configurations permet de mieux envisager plusieurs trajectoires d{\textquoteright}{\'e}volutions possibles pour les d{\'e}cennies {\`a} venir.Une entreprise d{\textquoteright}une ambition unique qui ouvre des perspectives nouvelles pour sortir de la crise actuelle. Toutes les donn{\'e}es collect{\'e}es au niveau des quelques 36 000 communes de France sont disponibles en ligne en acc{\`e}s libre sur le site unehistoireduconflitpolitique.fr, qui comprend des centaines de cartes, graphiques et tableaux interactifs auxquels le lecteur pourra se reporter afin d{\textquoteright}approfondir ses propres analyses et hypoth{\`e}ses.Julia Cag{\'e} est professeure {\`a} Sciences Po Paris et laur{\'e}ate du Prix du meilleur jeune {\'e}conomiste (2023).Thomas Piketty est directeur d{\textquoteright}{\'e}tudes {\`a} l{\textquoteright}{\'E}cole des hautes {\'e}tudes en sciences sociales et professeur {\`a} l{\textquoteright}{\'E}cole d{\textquoteright}{\'e}conomie de Paris.Ils signent ici leur premier livre en commun.},
	language = {fr},
	publisher = {Seuil},
	author = {Piketty, Thomas and Cag{\'e}, Julia},
	month = sep,
	year = {2023},
	note = {Google-Books-ID: 1qPNEAAAQBAJ},
	keywords = {Political Science / General},
}

